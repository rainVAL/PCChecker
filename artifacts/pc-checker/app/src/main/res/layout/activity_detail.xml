<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/iv_detail_image"
                    android:layout_width="match_parent"
                    android:layout_height="250dp"
                    android:scaleType="centerInside"
                    android:background="#FFFFFF"
                    android:contentDescription="Component Image" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#EEEEEE" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tv_detail_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Component Name"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#212121" />

                    <TextView
                        android:id="@+id/tv_detail_brand"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Brand Name"
                        android:textSize="16sp"
                        android:textColor="#757575"
                        android:layout_marginTop="4dp" />

                    <TextView
                        android:id="@+id/tv_detail_price"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="₱0.00"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#1A237E"
                        android:layout_marginTop="8dp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Detailed Description"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="#212121"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_detail_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="This is where the detailed description goes..."
                    android:textSize="14sp"
                    android:textColor="#424242"
                    android:lineSpacingExtra="4dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Specifications"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:textColor="#212121"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_detail_specs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Spec 1 | Spec 2 | Spec 3"
                    android:textSize="14sp"
                    android:textColor="#424242" />

                <TextView
                    android:id="@+id/tv_detail_score"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Performance Score: 0"
                    android:textSize="14sp"
                    android:textColor="#388E3C"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/btn_detail_select"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Add to Build"
            android:textSize="16sp"
            android:backgroundTint="#1A237E"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp" />

    </LinearLayout>
</ScrollView>
