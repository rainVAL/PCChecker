<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_component_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Component Name"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:textColor="#212121"/>

                <TextView
                    android:id="@+id/tv_component_brand"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Brand"
                    android:textSize="12sp"
                    android:textColor="#757575"
                    android:layout_marginTop="2dp"/>

                <TextView
                    android:id="@+id/tv_component_specs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Specs"
                    android:textSize="12sp"
                    android:textColor="#555555"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="end">

                <TextView
                    android:id="@+id/tv_component_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$0.00"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="#1A237E"/>

                <TextView
                    android:id="@+id/tv_component_tier"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mid"
                    android:textSize="11sp"
                    android:textColor="#757575"
                    android:layout_marginTop="2dp"/>

                <TextView
                    android:id="@+id/tv_component_score"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Score: 0"
                    android:textSize="11sp"
                    android:textColor="#388E3C"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tv_component_description"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Description goes here..."
            android:textSize="12sp"
            android:textColor="#424242"
            android:layout_marginTop="8dp"
            android:fontStyle="italic"/>

        <Button
            android:id="@+id/btn_select_component"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:text="Select"
            android:textSize="13sp"
            android:backgroundTint="#1A237E"
            android:layout_marginTop="10dp"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>
